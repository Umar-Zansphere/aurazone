<h2>Your Order is Out for Delivery!</h2>
<p>Hello <strong><%= customerName %></strong>,</p>
<p>Exciting news! Your order is out for delivery today and should arrive at your doorstep soon.</p>

<div style="background-color: #fff3cd; padding: 15px; border-radius: 5px; margin: 20px 0; border-left: 4px solid #ffc107;">
    <h3 style="color: #856404; margin-top: 0;">Expected Delivery Today</h3>
    <p style="color: #856404; margin: 0;"><strong>Delivery Window:</strong> <%= deliveryWindow || 'Between 9 AM - 6 PM' %></p>
</div>

<div style="background-color: #f9f9f9; padding: 15px; border-radius: 5px; margin: 20px 0;">
    <h3>Delivery Details</h3>
    <p><strong>Order Number:</strong> <%= orderNumber %></p>
    <p><strong>Order ID:</strong> <%= orderId %></p>
    <p><strong>Tracking Number:</strong> <%= trackingNumber %></p>
    <p><strong>Carrier:</strong> <%= carrier || 'Standard Delivery' %></p>
    <p><strong>Delivery Agent:</strong> <%= deliveryAgent || 'To be updated' %></p>
    <p><strong>Delivery Agent Contact:</strong> <%= deliveryAgentPhone || 'N/A' %></p>
</div>

<div style="background-color: #f9f9f9; padding: 15px; border-radius: 5px; margin: 20px 0;">
    <h3>Delivery Address</h3>
    <p><strong><%= addressLine1 %></strong></p>
    <% if (addressLine2) { %>
        <p><%= addressLine2 %></p>
    <% } %>
    <p><%= city %>, <%= state %> <%= postalCode %></p>
    <p><%= country %></p>
    <p><strong>Phone:</strong> <%= phone %></p>
</div>

<div style="background-color: #f9f9f9; padding: 15px; border-radius: 5px; margin: 20px 0;">
    <h3>Important Tips</h3>
    <ul style="margin: 10px 0; padding-left: 20px;">
        <li>Keep your phone available to help locate your address</li>
        <li>Ensure someone is available to receive the package</li>
        <li>Verify the package condition before accepting</li>
        <li>Keep your order number handy for reference</li>
    </ul>
</div>

<div style="text-align: center; margin: 30px 0;">
    <% if (trackingUrl) { %>
        <a href="<%= trackingUrl %>" style="background-color: #FF6B6B; color: #ffffff; padding: 12px 25px; text-decoration: none; border-radius: 5px; display: inline-block;">Track Live Status</a>
    <% } %>
</div>

<p>If you have any questions or need to reschedule the delivery, please contact our support team immediately.</p>
<p>Thank you for shopping with Aurazone!</p>
