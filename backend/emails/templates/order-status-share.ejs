<h2>Order Status Update</h2>
<p>Hello <strong><%= customerName %></strong>,</p>
<p>Here is the latest status for your order.</p>

<div style="background-color: #f9f9f9; padding: 15px; border-radius: 5px; margin: 20px 0;">
    <h3 style="margin-top: 0;">Order Snapshot</h3>
    <p><strong>Order Number:</strong> <%= orderNumber %></p>
    <p><strong>Order ID:</strong> <%= orderId %></p>
    <p><strong>Current Status:</strong> <span style="font-weight: 700;"><%= statusLabel %></span></p>
    <p><strong>Payment Status:</strong> <%= paymentStatusLabel %></p>
    <p><strong>Updated At:</strong> <%= new Date(updatedAt).toLocaleString() %></p>
</div>

<% if (trackingNumber || courierName || trackingUrl) { %>
<div style="background-color: #f9f9f9; padding: 15px; border-radius: 5px; margin: 20px 0;">
    <h3 style="margin-top: 0;">Shipment Details</h3>
    <p><strong>Courier:</strong> <%= courierName || 'Not assigned yet' %></p>
    <p><strong>Tracking Number:</strong> <%= trackingNumber || 'Not available' %></p>
    <% if (trackingUrl) { %>
        <p><a href="<%= trackingUrl %>" style="color: #0f766e; text-decoration: underline;">Track your order</a></p>
    <% } %>
</div>
<% } %>

<div style="background-color: #f9f9f9; padding: 15px; border-radius: 5px; margin: 20px 0;">
    <h3 style="margin-top: 0;">Order Items</h3>
    <table style="width: 100%; border-collapse: collapse;">
        <thead>
            <tr style="border-bottom: 2px solid #ddd;">
                <th style="text-align: left; padding: 10px;">Product</th>
                <th style="text-align: center; padding: 10px;">Qty</th>
            </tr>
        </thead>
        <tbody>
            <% items.forEach(item => { %>
                <tr style="border-bottom: 1px solid #eee;">
                    <td style="padding: 10px;">
                        <strong><%= item.productName %></strong><br/>
                        <small>Color: <%= item.color %> | Size: <%= item.size %></small>
                    </td>
                    <td style="text-align: center; padding: 10px;"><%= item.quantity %></td>
                </tr>
            <% }); %>
        </tbody>
    </table>
    <p style="margin-top: 12px;"><strong>Total:</strong> INR <%= Number(totalAmount || 0).toFixed(2) %></p>
</div>

<% if (note) { %>
<div style="background-color: #fff7ed; padding: 12px; border-left: 4px solid #f97316; border-radius: 4px; margin: 20px 0;">
    <strong>Note:</strong> <%= note %>
</div>
<% } %>

<p>If you have any questions, reply to this email and our team will help you.</p>
